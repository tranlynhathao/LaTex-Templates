---
import { getCategoryStateLabel, withBase } from "../lib/site";

const { category, index } = Astro.props;
const count = category.entry_counts?.total || 0;
const countLabel = count === 0 ? "—" : `${count} ${count === 1 ? "entry" : "entries"}`;
const indexLabel = typeof index === "number" ? String(index + 1).padStart(2, "0") : "";
---

<div class="category-list-row" data-state={category.category_state}>
  <span class="category-list-index">{indexLabel}</span>
  <span class="category-list-name">
    <a href={withBase(`/categories/${category.slug}`)}>{category.name}</a>
  </span>
  <span class="category-list-description">{category.description}</span>
  <span class="category-list-meta">
    <span class="category-card-state">{getCategoryStateLabel(category.category_state)}</span>
    <span class="category-card-count">{countLabel}</span>
  </span>
</div>
