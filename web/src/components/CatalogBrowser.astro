---
import TemplateCard from "./TemplateCard.astro";

const {
  entries,
  filterOptions,
  title = "Browse the catalog",
  copy = "",
  autofocus = false,
} = Astro.props;

const categoryOptions = filterOptions.categories.filter((category) => category.count > 0);
---

<section class="catalog-browser" data-catalog-browser data-autofocus={String(autofocus)}>
  <div class="catalog-browser-header">
    <div>
      <h2>{title}</h2>
      {copy && <p>{copy}</p>}
    </div>
    <p class="results-count" data-results-count>{entries.length} entries</p>
  </div>

  <form class="catalog-controls" data-catalog-controls>
    <label>
      <span>Search</span>
      <input type="search" name="q" placeholder="Search by name, tag, engine, or description" data-filter-search />
    </label>
    <label>
      <span>Category</span>
      <select name="category" data-filter-category>
        <option value="">All populated categories</option>
        {categoryOptions.map((category) => (
          <option value={category.id}>{category.name}</option>
        ))}
      </select>
    </label>
    <label>
      <span>Engine</span>
      <select name="engine" data-filter-engine>
        <option value="">All engines</option>
        {filterOptions.engines.map((engine) => (
          <option value={engine}>{engine}</option>
        ))}
      </select>
    </label>
    <label>
      <span>Kind</span>
      <select name="kind" data-filter-kind>
        <option value="">All entry types</option>
        {filterOptions.kinds.map((kind) => (
          <option value={kind}>{kind}</option>
        ))}
      </select>
    </label>
    <label class="catalog-checkbox">
      <input type="checkbox" name="featured" data-filter-featured />
      <span>Featured only</span>
    </label>
  </form>

  <div class="card-grid" data-card-grid>
    {entries.map((entry) => (
      <TemplateCard entry={entry} />
    ))}
  </div>

  <div class="empty-state" data-empty-state hidden>
    <h3>No entries match these filters.</h3>
    <p>Try clearing one or more filters, or browse categories directly.</p>
  </div>
</section>

<script is:inline>
  const formatCount = (count) => `${count} ${count === 1 ? "entry" : "entries"}`;

  const browsers = document.querySelectorAll("[data-catalog-browser]");

  for (const browser of browsers) {
    const params = new URLSearchParams(window.location.search);
    const searchInput = browser.querySelector("[data-filter-search]");
    const categorySelect = browser.querySelector("[data-filter-category]");
    const engineSelect = browser.querySelector("[data-filter-engine]");
    const kindSelect = browser.querySelector("[data-filter-kind]");
    const featuredInput = browser.querySelector("[data-filter-featured]");
    const cards = browser.querySelectorAll("[data-template-card]");
    const countNode = browser.querySelector("[data-results-count]");
    const emptyNode = browser.querySelector("[data-empty-state]");

    if (searchInput && params.get("q")) searchInput.value = params.get("q");
    if (categorySelect && params.get("category")) categorySelect.value = params.get("category");
    if (engineSelect && params.get("engine")) engineSelect.value = params.get("engine");
    if (kindSelect && params.get("kind")) kindSelect.value = params.get("kind");
    if (featuredInput && params.get("featured") === "1") featuredInput.checked = true;

    const syncUrl = () => {
      const nextParams = new URLSearchParams();

      if (searchInput?.value.trim()) nextParams.set("q", searchInput.value.trim());
      if (categorySelect?.value) nextParams.set("category", categorySelect.value);
      if (engineSelect?.value) nextParams.set("engine", engineSelect.value);
      if (kindSelect?.value) nextParams.set("kind", kindSelect.value);
      if (featuredInput?.checked) nextParams.set("featured", "1");

      const nextQuery = nextParams.toString();
      const nextUrl = nextQuery ? `${window.location.pathname}?${nextQuery}` : window.location.pathname;
      window.history.replaceState({}, "", nextUrl);
    };

    const applyFilters = () => {
      const query = searchInput?.value.trim().toLowerCase() || "";
      const category = categorySelect?.value || "";
      const engine = engineSelect?.value || "";
      const kind = kindSelect?.value || "";
      const featuredOnly = featuredInput?.checked || false;

      let visibleCount = 0;

      cards.forEach((card) => {
        const searchText = card.dataset.search || "";
        const matchesQuery = !query || searchText.includes(query);
        const matchesCategory = !category || card.dataset.category === category;
        const matchesEngine = !engine || card.dataset.engine === engine;
        const matchesKind = !kind || card.dataset.kind === kind;
        const matchesFeatured = !featuredOnly || card.dataset.featured === "true";

        const visible =
          matchesQuery && matchesCategory && matchesEngine && matchesKind && matchesFeatured;

        card.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      if (countNode) countNode.textContent = formatCount(visibleCount);
      if (emptyNode) emptyNode.hidden = visibleCount !== 0;

      syncUrl();
    };

    [searchInput, categorySelect, engineSelect, kindSelect, featuredInput].forEach((control) => {
      control?.addEventListener("input", applyFilters);
      control?.addEventListener("change", applyFilters);
    });

    if (searchInput && browser.dataset.autofocus === "true") {
      searchInput.focus();
    }

    applyFilters();
  }
</script>
