---
import { getCategoryStateLabel, withBase } from "../lib/site";

const { category, index } = Astro.props;
const count = category.entry_counts?.total || 0;
const countLabel = count === 0 ? "Empty" : `${count} ${count === 1 ? "entry" : "entries"}`;
const indexLabel =
  typeof index === "number" ? String(index + 1).padStart(2, "0") : null;
---

<article class="category-card" data-state={category.category_state}>
  <div class="category-card-head">
    {indexLabel && <span class="category-card-index">{indexLabel}</span>}
    <span class="category-card-state">{getCategoryStateLabel(category.category_state)}</span>
  </div>
  <h3 class="category-card-title">
    <a href={withBase(`/categories/${category.slug}`)}>{category.name}</a>
  </h3>
  <p class="category-card-description">{category.description}</p>
  <div class="category-card-footer">
    <span class="category-card-count">{countLabel}</span>
    {category.shared_family && (
      <span class="ink-muted">Family · {category.shared_family}</span>
    )}
  </div>
</article>
