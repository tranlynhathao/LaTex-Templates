---
import Badge from "./Badge.astro";
import { getCategoryStateLabel, getCategoryStateTone, withBase } from "../lib/site";

const { category } = Astro.props;
const count = category.entry_counts?.total || 0;
const countLabel = `${count} ${count === 1 ? "entry" : "entries"}`;
---

<article class="category-card">
  <div class="card-meta-row">
    <span class="eyebrow">Category</span>
    <span class="source-path">{category.slug}</span>
  </div>
  <h3 class="card-title">
    <a href={withBase(`/categories/${category.slug}`)}>{category.name}</a>
  </h3>
  <p class="card-description">{category.description}</p>
  <div class="badge-row">
    <Badge text={getCategoryStateLabel(category.category_state)} tone={getCategoryStateTone(category.category_state)} />
    <Badge text={countLabel} tone="outline" />
  </div>
  {category.shared_family && (
    <p class="card-supporting">Shared family: {category.shared_family}</p>
  )}
</article>
