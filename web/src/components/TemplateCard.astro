---
import Badge from "./Badge.astro";
import PreviewTile from "./PreviewTile.astro";
import { withBase } from "../lib/site";

const { entry } = Astro.props;
---

<article
  class="template-card"
  data-template-card
  data-search={entry.catalog.search_text}
  data-category={entry.category}
  data-engine={entry.engine}
  data-kind={entry.kind}
  data-featured={String(entry.featured)}
>
  <PreviewTile entry={entry} />
  <div class="template-card-body">
    <div class="card-meta-row">
      <span class="eyebrow">{entry.category_data?.name || entry.category}</span>
      <span class="source-path">{entry.template_root}</span>
    </div>
    <h3 class="card-title">
      <a href={withBase(`/templates/${entry.slug}`)}>{entry.name}</a>
    </h3>
    <p class="card-description">{entry.description}</p>
    <div class="badge-row">
      <Badge text={entry.catalog.kind_label} tone={entry.kind === "scaffold" ? "accent" : "success"} />
      <Badge text={entry.catalog.maturity_label} tone="subtle" />
      <Badge text={entry.engine} tone="outline" />
    </div>
    <p class="card-supporting">
      {entry.catalog.compilation_label}
      {entry.site_assets?.preview_document_url ? " • Preview PDF available" : " • No preview PDF yet"}
    </p>
  </div>
</article>
