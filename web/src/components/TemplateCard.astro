---
import PreviewTile from "./PreviewTile.astro";
import { withBase } from "../lib/site";

const { entry } = Astro.props;
const categoryName = entry.category_data?.name || entry.category;
const engineLabel = entry.engine?.toUpperCase();
const kindLabel = entry.catalog?.kind_label || (entry.kind === "scaffold" ? "Scaffold" : "Template");
---

<article
  class="template-card"
  data-template-card
  data-search={entry.catalog.search_text}
  data-category={entry.category}
  data-engine={entry.engine}
  data-kind={entry.kind}
  data-featured={String(entry.featured)}
>
  <a href={withBase(`/templates/${entry.slug}`)} aria-label={`Open ${entry.name}`} style="display:contents">
    <PreviewTile entry={entry} />
  </a>
  <div class="template-card-body">
    <div class="template-card-meta">
      <span>{categoryName}</span>
      <span class="status-dot" data-kind={entry.kind}>{kindLabel}</span>
      {entry.featured && <span class="template-card-pin">Pinned</span>}
    </div>
    <h3 class="template-card-title">
      <a href={withBase(`/templates/${entry.slug}`)}>{entry.name}</a>
    </h3>
    <p class="template-card-description">{entry.description}</p>
    <div class="template-card-footer">
      <div class="template-card-footer-left">
        <span class="mono">{engineLabel}</span>
        <span aria-hidden="true" class="ink-subtle">·</span>
        <span>{entry.catalog.maturity_label}</span>
      </div>
      <span class="source-path" title={entry.template_root}>{entry.template_root}</span>
    </div>
  </div>
</article>
