---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  getCategories,
  getFeaturedEntries,
  getEntries,
  getSiteData,
} from "../lib/catalog";
import { withBase } from "../lib/site";

const siteData = getSiteData();
const allEntries = getEntries();
const featuredEntries = getFeaturedEntries();
const categories = getCategories();

const realTemplateCount = siteData.summary.real_template_count;
const scaffoldCount = siteData.summary.scaffold_count;
const totalCategories = siteData.summary.category_count;
const populatedCategories = categories.filter((c) => (c.entry_counts?.total || 0) > 0);
const plannedCount = categories.filter((c) => c.category_state === "empty-placeholder").length;

const vocabulary = [
  {
    kind: "real-template",
    label: "Real template",
    count: realTemplateCount,
    copy: "A ready-to-compile package.",
  },
  {
    kind: "scaffold",
    label: "Scaffold",
    count: scaffoldCount,
    copy: "A shared compile profile for future documents.",
  },
  {
    kind: "placeholder",
    label: "Planned",
    count: plannedCount,
    copy: "A named slot with no entries yet.",
  },
];

const populatedEntriesByCategory = populatedCategories.map((category) => ({
  category,
  entries: allEntries.filter((e) => e.category === category.id),
}));

const destinations = [
  { href: "/templates", eyebrow: "Browse", title: "Templates" },
  { href: "/categories", eyebrow: "Taxonomy", title: "Categories" },
  { href: "/search", eyebrow: "Find", title: "Search" },
  { href: "/featured", eyebrow: "Pinned", title: "Featured" },
];

const featuredTeaser = featuredEntries[0] || null;
---

<BaseLayout
  title="Overview"
  description="A static catalog of curated LaTeX templates and scaffolds."
>
  <section class="intro-hero">
    <div class="container intro-hero-inner">
      <p class="eyebrow">LaTeX gallery · v0.1</p>
      <h1 class="intro-hero-headline">
        A quiet catalog of LaTeX templates.
      </h1>
      <p class="intro-hero-lead">
        Generated from the repository registry. Real templates, shared scaffolds, and planned
        categories are each shown honestly.
      </p>
      <div class="button-row">
        <a class="button button-primary" href={withBase("/templates")}>Enter the catalog</a>
        <a class="button button-ghost" href={withBase("/categories")}>Taxonomy</a>
      </div>
    </div>
  </section>

  <section class="section intro-vocabulary">
    <div class="container">
      <div class="intro-section-head">
        <p class="eyebrow">States</p>
      </div>
      <dl class="vocab-grid">
        {vocabulary.map((item) => (
          <div class="vocab-item">
            <dt>
              <span class="status-dot" data-kind={item.kind}>{item.label}</span>
              <span class="vocab-count">{item.count}</span>
            </dt>
            <dd>{item.copy}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="section section-inset intro-today">
    <div class="container">
      <div class="intro-section-head">
        <p class="eyebrow">Today</p>
      </div>
      <div class="intro-today-body">
        <p class="intro-today-lead">
          <strong>{realTemplateCount}</strong>
          {realTemplateCount === 1 ? "real template" : "real templates"},
          <strong>{scaffoldCount}</strong>
          {scaffoldCount === 1 ? "scaffold" : "scaffolds"},
          <strong>{totalCategories}</strong>
          {totalCategories === 1 ? "category" : "categories"}.
        </p>
        {populatedEntriesByCategory.length > 0 && (
          <div class="intro-today-list" aria-label="Populated categories">
            {populatedEntriesByCategory.map(({ category, entries }) => (
              <div class="intro-today-row">
                <a class="intro-today-cat" href={withBase(`/categories/${category.slug}`)}>
                  {category.name}
                </a>
                <span class="intro-today-entries">
                  {entries.map((entry, index) => (
                    <>
                      <a href={withBase(`/templates/${entry.slug}`)}>{entry.name}</a>
                      {index < entries.length - 1 && <span class="ink-subtle">, </span>}
                    </>
                  ))}
                </span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="section intro-destinations">
    <div class="container">
      <ul class="destination-list">
        {destinations.map((item) => (
          <li class="destination-item">
            <a class="destination-link" href={withBase(item.href)}>
              <span class="destination-eyebrow">{item.eyebrow}</span>
              <span class="destination-title">{item.title}</span>
              <span class="destination-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
