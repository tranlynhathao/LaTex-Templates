---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/site";
---

<BaseLayout
  title="Not Found"
  description="The requested catalog page could not be found."
>
  <section class="container error-block">
    <p class="error-code">404 · Route not generated</p>
    <h1 style="margin-bottom:1rem;max-width:18ch;margin-inline:auto;">
      This page isn't in the catalog.
    </h1>
    <p class="lead" style="margin-inline:auto;">
      The registry did not generate a page for this URL. Browse the catalog or category index to
      continue.
    </p>
    <div class="button-row" style="justify-content:center;margin-top:1.75rem;">
      <a class="button button-primary" href={withBase("/templates")}>Browse templates</a>
      <a class="button button-ghost" href={withBase("/categories")}>View categories</a>
    </div>
  </section>
</BaseLayout>
