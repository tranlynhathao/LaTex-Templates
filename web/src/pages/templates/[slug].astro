---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Badge from "../../components/Badge.astro";
import EmptyState from "../../components/EmptyState.astro";
import PreviewTile from "../../components/PreviewTile.astro";
import TemplateCard from "../../components/TemplateCard.astro";
import { getEntries, getRelatedEntries } from "../../lib/catalog";
import {
  getRepositoryBlobUrl,
  getRepositoryTreeUrl,
  withBase,
} from "../../lib/site";

export function getStaticPaths() {
  return getEntries().map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const relatedEntries = getRelatedEntries(entry);
const previewDocumentUrl = entry.site_assets?.preview_document_url
  ? withBase(entry.site_assets.preview_document_url)
  : null;
const downloadArchiveUrl = entry.site_assets?.download_archive_url
  ? withBase(entry.site_assets.download_archive_url)
  : null;
const sourceDirectoryUrl = getRepositoryTreeUrl(entry.template_root);
const metadataUrl = getRepositoryBlobUrl(entry.metadata_file);
const readmeUrl = getRepositoryBlobUrl(entry.readme_file);
const categoryName = entry.category_data?.name || entry.category;
const kindTone = entry.kind === "scaffold" ? "accent" : "success";

const facts = [
  { label: "Category", value: categoryName, serif: true },
  { label: "Kind", value: entry.catalog.kind_label },
  { label: "Maturity", value: entry.catalog.maturity_label },
  { label: "Engine", value: entry.engine },
  { label: "Main file", value: entry.main_file },
  { label: "Language", value: entry.language },
  { label: "Version", value: entry.version },
  { label: "License", value: entry.license },
  { label: "Compile", value: entry.catalog.compilation_label },
  { label: "Updated", value: entry.updated_at },
];
---

<BaseLayout title={entry.name} description={entry.description}>
  <section class="detail-hero">
    <div class="container">
      <nav class="detail-breadcrumbs" aria-label="Breadcrumb">
        <a href={withBase("/templates")}>Templates</a>
        <span class="detail-breadcrumbs-sep">/</span>
        <a href={withBase(`/categories/${entry.category_data?.slug || entry.category}`)}>
          {categoryName}
        </a>
        <span class="detail-breadcrumbs-sep">/</span>
        <span>{entry.name}</span>
      </nav>
      <div class="detail-hero-grid">
        <div>
          <p class="eyebrow">{categoryName}</p>
          <h1>{entry.name}</h1>
          <p class="lead">{entry.description}</p>
          <div class="badge-row" style="margin-bottom:1.75rem;">
            <Badge text={entry.catalog.kind_label} tone={kindTone} dot />
            <Badge text={entry.catalog.maturity_label} tone="subtle" />
            <Badge text={entry.engine.toUpperCase()} tone="outline" />
            <Badge text={entry.catalog.compilation_label} tone="outline" />
            {entry.featured && <Badge text="Featured" tone="strong" />}
          </div>
          <div class="detail-actions">
            {previewDocumentUrl ? (
              <a class="button button-primary" href={previewDocumentUrl} target="_blank" rel="noreferrer">
                Open PDF
              </a>
            ) : (
              <span class="button button-disabled">No PDF</span>
            )}
            {downloadArchiveUrl ? (
              <a class="button button-secondary" href={downloadArchiveUrl}>
                Download
              </a>
            ) : sourceDirectoryUrl ? (
              <a class="button button-secondary" href={sourceDirectoryUrl} target="_blank" rel="noreferrer">
                View source
              </a>
            ) : (
              <span class="button button-disabled">No source link</span>
            )}
          </div>
        </div>
        <div class="detail-hero-preview">
          <PreviewTile entry={entry} size="hero" />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container detail-grid">
      <div class="detail-main">
        {entry.intended_use && (
          <section class="detail-section">
            <h2>Intended for</h2>
            <p class="ink-muted" style="font-size:1.02rem;line-height:1.65;">
              {entry.intended_use}.
            </p>
          </section>
        )}

        {entry.notes?.length > 0 && (
          <section class="detail-section">
            <h2>Notes</h2>
            <ul class="detail-list">
              {entry.notes.map((note) => (
                <li>{note}</li>
              ))}
            </ul>
          </section>
        )}

        {entry.dependencies?.length > 0 && (
          <section class="detail-section">
            <h2>Dependencies</h2>
            <div class="badge-row">
              {entry.dependencies.map((dependency) => (
                <Badge text={dependency} tone="outline" />
              ))}
            </div>
          </section>
        )}

        {entry.tags?.length > 0 && (
          <section class="detail-section">
            <h2>Tags</h2>
            <div class="badge-row">
              {entry.tags.map((tag) => (
                <Badge text={`#${tag}`} tone="subtle" />
              ))}
            </div>
          </section>
        )}

        <section class="detail-section">
          <h2>Sources</h2>
          <ul class="detail-source-list">
            <li>
              <span class="detail-source-list-label">Source</span>
              <span class="detail-source-list-value">
                {sourceDirectoryUrl ? (
                  <a href={sourceDirectoryUrl} target="_blank" rel="noreferrer">{entry.template_root}</a>
                ) : (
                  entry.template_root
                )}
              </span>
            </li>
            <li>
              <span class="detail-source-list-label">Metadata</span>
              <span class="detail-source-list-value">
                {metadataUrl ? (
                  <a href={metadataUrl} target="_blank" rel="noreferrer">{entry.metadata_file}</a>
                ) : (
                  entry.metadata_file
                )}
              </span>
            </li>
            <li>
              <span class="detail-source-list-label">README</span>
              <span class="detail-source-list-value">
                {readmeUrl ? (
                  <a href={readmeUrl} target="_blank" rel="noreferrer">{entry.readme_file}</a>
                ) : (
                  entry.readme_file
                )}
              </span>
            </li>
            <li>
              <span class="detail-source-list-label">Main file</span>
              <span class="detail-source-list-value">{entry.main_file}</span>
            </li>
          </ul>
        </section>
      </div>

      <aside class="detail-sidebar" aria-label="Quick facts">
        <div class="detail-facts">
          <dl>
            {facts.map((fact) => fact.value && (
              <div class:list={["detail-facts-row", fact.serif && "detail-facts-row-serif"]}>
                <dt>{fact.label}</dt>
                <dd>{fact.value}</dd>
              </div>
            ))}
          </dl>
        </div>
        {entry.author && (
          <p class="ink-muted" style="font-size:0.82rem;">
            Maintained by {entry.author}.
          </p>
        )}
      </aside>
    </div>
  </section>

  {relatedEntries.length > 0 && (
    <section class="section section-inset">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow">Related</p>
          <a class="arrow-link" href={withBase("/templates")}>All entries</a>
        </div>
        <div class="card-grid">
          {relatedEntries.map((relatedEntry) => (
            <TemplateCard entry={relatedEntry} />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
