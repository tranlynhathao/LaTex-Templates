---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Badge from "../../components/Badge.astro";
import EmptyState from "../../components/EmptyState.astro";
import TemplateCard from "../../components/TemplateCard.astro";
import { getBootstrapEntry, getCategories, getEntriesByCategory } from "../../lib/catalog";
import { getCategoryStateLabel, getCategoryStateTone, withBase } from "../../lib/site";

export function getStaticPaths() {
  return getCategories().map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const entries = getEntriesByCategory(category.id);
const bootstrapEntry = getBootstrapEntry(category);
const entryCount = category.entry_counts?.total || 0;
const entryCountLabel = `${entryCount} ${entryCount === 1 ? "entry" : "entries"}`;
---

<BaseLayout title={category.name} description={category.description}>
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow">Category</p>
      <h1>{category.name}</h1>
      <p class="lead">{category.description}</p>
      <div class="badge-row">
        <Badge
          text={getCategoryStateLabel(category.category_state)}
          tone={getCategoryStateTone(category.category_state)}
        />
        <Badge
          text={entryCountLabel}
          tone="outline"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {entries.length ? (
        <div class="card-grid">
          {entries.map((entry) => (
            <TemplateCard entry={entry} />
          ))}
        </div>
      ) : (
        <EmptyState
          title="No catalog entries in this category yet"
          copy="This category is intentionally present as part of the long-term taxonomy, but it does not currently contain a registered template."
        />
      )}
    </div>
  </section>

  {bootstrapEntry && !entries.length && (
    <section class="section section-alt">
      <div class="container narrow">
        <p class="eyebrow">Bootstrap Source</p>
        <h2>Reference starting point</h2>
        <p class="lead">
          Future entries in this category are expected to derive from the report-family scaffold.
        </p>
        <p>
          <a class="text-link" href={withBase(`/templates/${bootstrapEntry.slug}`)}>
            Open {bootstrapEntry.name}
          </a>
        </p>
      </div>
    </section>
  )}
</BaseLayout>
